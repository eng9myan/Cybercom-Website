# CyberCom Platform API Integration — Environment Variables
# Copy this file to .env and fill in values for your environment.
# For static hosting, these are embedded at build time via esbuild --define.

# ─── Core API ──────────────────────────────────────────────────────────────
# Base URL of the CyberCom Platform backend API
CYBERCOM_API_URL=https://api.cy-com.com

# API version prefix (v1, v2, etc.)
CYBERCOM_API_VERSION=v1

# Request timeout in milliseconds
CYBERCOM_API_TIMEOUT=30000

# ─── CyIdentity (OAuth 2.1 / OIDC) ────────────────────────────────────────
# CyIdentity OIDC issuer URL (P2.1)
CYIDENTITY_URL=https://identity.cy-com.com

# OAuth 2.1 client IDs for the public website (no secret — PKCE flow)
CYIDENTITY_WEBSITE_CLIENT_ID=cybercom-website-public

# Callback URL after login
CYIDENTITY_REDIRECT_URI=https://cy-com.com/auth/callback

# Post-logout redirect URI
CYIDENTITY_POST_LOGOUT_URI=https://cy-com.com

# OAuth scopes requested
CYIDENTITY_SCOPES=openid profile email cybercom.read

# ─── Portal URLs ───────────────────────────────────────────────────────────
# Patient / citizen portal (CyMed Patient Portal — P3.6)
PORTAL_URL=https://portal.cy-com.com

# Healthcare / clinical portal (CyMed Provider Portal — P3.7)
HEALTH_URL=https://health.cy-com.com

# Provider management portal (CyMed Provider Portal — P3.7)
PROVIDER_URL=https://provider.cy-com.com

# ─── Service Health Endpoints (for /admin/platform-status) ────────────────
CYMED_HEALTH_URL=https://api.cy-com.com/cymed/health/
CYCOM_HEALTH_URL=https://api.cy-com.com/cycom/health/
CYGOV_HEALTH_URL=https://api.cy-com.com/cygov/health/
CYIDENTITY_HEALTH_URL=https://identity.cy-com.com/health/
CYAI_HEALTH_URL=https://api.cy-com.com/cyai/health/
CYDATA_HEALTH_URL=https://api.cy-com.com/cydata/health/
CYINTEGRATIONHUB_HEALTH_URL=https://api.cy-com.com/hub/health/

# ─── Website APIs (served from CyberCom Platform) ─────────────────────────
PRODUCTS_API_URL=https://api.cy-com.com/v1/website/products/
INDUSTRIES_API_URL=https://api.cy-com.com/v1/website/industries/
PARTNERS_API_URL=https://api.cy-com.com/v1/website/partners/
DEMO_API_URL=https://api.cy-com.com/v1/website/demo-requests/
CONTACT_API_URL=https://api.cy-com.com/v1/website/contact/
DOCS_API_URL=https://api.cy-com.com/v1/website/docs/

# ─── Monitoring ────────────────────────────────────────────────────────────
# Admin status dashboard refresh interval in milliseconds
STATUS_REFRESH_INTERVAL=30000
